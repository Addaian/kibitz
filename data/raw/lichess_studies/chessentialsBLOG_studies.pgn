[Event "Step 8 Conclusion"]
[Date "2023.03.26"]
[White "Nemec, Vjekoslav"]
[Black "Vrban, Mladen"]
[Result "1/2-1/2"]
[WhiteElo "2239"]
[BlackElo "2275"]
[Annotator "USER"]
