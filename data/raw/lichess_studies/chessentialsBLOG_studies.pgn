[White "Vasily Smyslov"]
[Black "Vladimir Mikhailovich Liberzo"]
[Result "1-0"]
[Annotator "mistr"]
[Variant "Standard"]
[ECO "A25"]
[Opening "English Opening: King's English Variation, Hungarian Attack"]
