[Event "960 Starting positions and square control: Bishop."]
[Date "2020.12.23"]
[Result "*"]
[Variant "Standard"]
[ECO "?"]
[Opening "?"]
[StudyName "960 Starting positions and square control"]
[ChapterName "Bishop."]
[ChapterURL "https://lichess.org/study/5do3bfAh/Jb1czVkk"]
[Annotator "https://lichess.org/@/Tasshaq"]
[FEN "8/8/8/8/8/8/8/BBBBBBBB w - - 0 1"]
[SetUp "1"]
[UTCDate "2020.12.23"]
[UTCTime "11:24:31"]

{ On a1-h1 bishop controls only 3 squares.
b1-g1: 3+1= 4
c1-f1: 3+2=5
d1-e1: 3+3=6 (the maximum) } { [%cal Ga1d4,Gb1a2,Gb1e4,Gc1a3,Gc1f4,Gd1a4,Ge1h4,Gd1g4,Ge1b4,Gf1c4,Gg1d4,Gf1h3,Gg1h2,Gh1e4,Gb5h5,Gg5a5] }
