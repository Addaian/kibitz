[Event "Techniques in Rook + Pawn vs Rook: Defending #1"]
[Site "https://lichess.org/study/q99sypzd/QL0XCc8g"]
[Date "2021.02.05"]
[Result "*"]
[Annotator "https://lichess.org/@/pepellou"]
