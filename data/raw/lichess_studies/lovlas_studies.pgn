[Event "Tournament"]
[Date "2020.03.18"]
[Round "2.1"]
[White "Caruana, Fabiano"]
[Black "Alekseenko, Kirill"]
[Result "1-0"]
[Variant "Standard"]
[ECO "E20"]
[Opening "Nimzo-Indian Defense: Kmoch Variation"]
[StudyName "The Candidates Tournament 2020 - Round 2"]
[ChapterName "Caruana, Fabiano - Alekseenko, Kirill"]
