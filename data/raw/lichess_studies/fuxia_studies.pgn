[StudyName "Réti Opening: 1.Nf3 d5 2.c4"]
[ChapterName "2...dxc4 - Réti Accepted"]
[ChapterURL "https://lichess.org/study/PI8tnkhk/Mtj9yVF0"]
[Annotator "https://lichess.org/@/fuxia"]
[UTCDate "2019.08.12"]
