1. e4 { [%eval 0.0] [%clk 0:15:10] } 1... c5 { [%eval 0.0] [%clk 0:15:10] } 2. Nf3 { [%eval 0.0] [%clk 0:14:47] } 2... d6 { [%eval 0.0] [%clk 0:15:08] } 3. d4 { [%eval 0.0] [%clk 0:14:53] } 3... cxd4 { [%eval 0.17] [%clk 0:15:16] } 4. Nxd4 { [%eval 0.0] [%clk 0:15:03] } 4... Nf6 { [%eval 0.23] [%clk 0:15:25] } 5. Bc4 { [%eval -0.13] [%clk 0:15:06] } 5... Nxe4 { [%eval 0.0] [%clk 0:15:34] } 6. Qh5 { [%eval -0.33] [%clk 0:15:10] } 6... e6 { [%eval -0.13] [%clk 0:15:41] } 7. Nxe6?? { [%eval -2.7] } { Blunder. Bb5+ was best. } { Carlsen messed up the move order here. } { [%clk 0:08:49] } (7. Bb5+ Nd7 8. Nxe6 { Now you can take! } 8... Nf6 9. Nxd8 Nxh5 10. Bxd7+ Bxd7 11. Nxb7 Bc6) 7... Bxe6 { [%eval -2.35] [%clk 0:13:40] } 8. Bxe6 { [%eval -2.46] [%clk 0:08:57] } 8... Qe7 { [%eval -2.54] [%clk 0:13:49] } 9. Bxf7+ { [%eval -3.07] [%clk 0:05:55] } 9... Qxf7 { [%eval -3.06] [%clk 0:13:56] } 10. Qe2 { [%eval -3.14] [%clk 0:06:04] } 10... Qe7 { [%eval -2.98] [%clk 0:12:40] } 11. O-O { [%eval -2.95] [%clk 0:06:05] } 11... Nf6 { [%eval -2.84] [%clk 0:12:48] } 12. Be3 { [%eval -3.33] [%clk 0:05:36] } 12... Nc6 { [%eval -3.08] [%clk 0:12:47] } 13. Nc3 { [%eval -3.28] [%clk 0:04:58] } 13... d5 { [%eval -3.07] [%clk 0:12:44] } 14. Qf3 { [%eval -3.25] [%clk 0:04:33] } 14... O-O-O { [%eval -3.2] [%clk 0:12:42] } 15. Rfe1 { [%eval -3.63] [%clk 0:04:40] } 15... Qd7 { [%eval -3.59] [%clk 0:12:47] } 16. Nb5 { [%eval -3.69] [%clk 0:04:37] } 16... a6 { [%eval -3.63] [%clk 0:12:44] } 17. a4 { [%eval -4.54] [%clk 0:04:48] } 17... Qg4?! { [%eval -3.52] } { Inaccuracy. axb5 was best. } { [%clk 0:12:50] } (17... axb5) 18. Qxg4+ { [%eval -3.93] [%clk 0:04:49] } 18... Nxg4 { [%eval -3.77] [%clk 0:12:57] } 19. Bb6 { [%eval -4.3] [%clk 0:04:59] } 19... axb5 { [%eval -4.25] [%clk 0:12:51] } 20. axb5 { [%eval -3.92] [%clk 0:05:02] } 20... Nb8 { [%eval -3.9] [%clk 0:13:00] } 21. Bxd8 { [%eval -4.22] [%clk 0:04:50] } 21... Kxd8 { [%eval -4.17] [%clk 0:13:08] } 22. h3 { [%eval -3.95] [%clk 0:03:47] } 22... Nf6 { [%eval -4.0] [%clk 0:13:14] } 23. Ra7?! { [%eval -5.42] } { Inaccuracy. c4 was best. } { [%clk 0:03:48] } (23. c4 Bb4) 23... Kc7 { [%eval -5.22] [%clk 0:13:19] } 24. Re6 { [%eval -5.86] [%clk 0:03:44] } 24... Bc5 { [%eval -5.35] [%clk 0:13:25] } 25. b6+ { [%eval -6.2] [%clk 0:03:52] } 25... Bxb6 { [%eval -6.07] [%clk 0:13:06] } 26. Re7+ { [%eval -6.81] [%clk 0:04:00] } 26... Kd6?! { [%eval -4.99] } { Inaccuracy. Nbd7 was best. } { [%clk 0:13:13] } (26... Nbd7) 27. Raxb7 { [%eval -4.89] [%clk 0:04:04] } 27... Nbd7 { [%eval -4.78] [%clk 0:13:20] } 28. Rxg7 { [%eval -4.72] [%clk 0:04:07] } 28... Kc6 { [%eval -4.02] } { 0-1 White resigns. } { [%clk 0:13:28] } 0-1


