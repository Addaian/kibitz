[Opening "Caro-Kann Defense: Accelerated Panov Attack, Modern Variation"]
[StudyName "Caro-Kann Defense. The Theory"]
[ChapterName "Accelerated Panov/Main Line: 2.c4 d5"]
[ChapterURL "https://lichess.org/study/4Aqycynk/rgG01zz6"]
[Annotator "https://lichess.org/@/fuxia"]
