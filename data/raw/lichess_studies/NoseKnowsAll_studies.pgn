[Variant "Standard"]
[ECO "C77"]
[Opening "Ruy Lopez: Morphy Defense, Anderssen Variation"]
[StudyName "Fischer's My 60 Memorable Games"]
[ChapterName "Robert James Fischer - Vasily Smyslov"]
