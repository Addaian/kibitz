[Annotator "https://lichess.org/@/NoseKnowsAll"]
[FEN "rn1qkbnr/pp2pppp/2p5/3pPb2/3P3P/8/PPP2PP1/RNBQKBNR b KQkq - 0 4"]
[SetUp "1"]
