[WhiteElo "2761"]
[BlackElo "2708"]
[Annotator "https://lichess.org/@/Mr_Penings"]
[Variant "Standard"]
[ECO "E97"]
[Opening "King's Indian Defense: Orthodox Variation, Modern System"]
