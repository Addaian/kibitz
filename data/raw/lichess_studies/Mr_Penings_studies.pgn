[Event "🏆 Nimzo/Bogo Indian Repertoire 🏆: Nimzo/Bogo Indian Introduction/Ideas"]
[Site "https://lichess.org/study/DeAekads/Fo4wntxQ"]
[Date "2020.06.23"]
[Result "*"]
[Annotator "https://lichess.org/@/Mr_Penings"]
[Variant "Standard"]
