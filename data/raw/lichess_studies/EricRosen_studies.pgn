[Round "13"]
[White "Mikhail Botvinnik"]
[Black "Milan Vidmar"]
[Result "1-0"]
[Variant "Standard"]
[ECO "D60"]
[Opening "Queen's Gambit Declined: Orthodox Defense, Botvinnik Variation"]
[StudyName "Classics"]
[ChapterName "Mikhail Botvinnik - Milan Vidmar"]
[ChapterURL "https://lichess.org/study/bJfvHqtx/6NvPyYBb"]
