[Round "6.7"]
[White "Eric S Rosen"]
[Black "Simen Agdestein"]
[Result "1-0"]
[WhiteElo "2369"]
[BlackElo "2604"]
[Annotator "Rosen,Eric"]
[Variant "Standard"]
[ECO "D00"]
[Opening "Queen's Pawn Game: Accelerated London System"]
