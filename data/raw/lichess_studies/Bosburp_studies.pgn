[Event "Pure Brilliancy: Volume II: Rotlewi vs Rubinstein – Notes"]
[Date "2025.07.28"]
[White "Georg Rotlewi"]
[Black "Akiba Rubinstein"]
[Result "*"]
[Variant "Standard"]
