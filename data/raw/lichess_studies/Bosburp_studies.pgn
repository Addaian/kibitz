[ChapterName "📕 5...Nxe4 with 6...Nd7"]
[ChapterURL "https://lichess.org/study/64DHMYix/t093X1tH"]
[Annotator "https://lichess.org/@/Bosburp"]
[FEN "rnbqkb1r/pp2pppp/2p2n2/8/4N3/5N2/PPPP1PPP/R1BQKB1R w KQkq - 1 5"]
[SetUp "1"]
