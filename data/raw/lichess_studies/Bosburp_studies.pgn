[White "Mikhail Tal"]
[Black "NN"]
[Result "1-0"]
[Variant "Standard"]
[ECO "B96"]
[Opening "Sicilian Defense: Najdorf Variation, Polugaevsky Variation, Simagin Line"]
[StudyName "Mikhail Tal's BRILLIANT Games: Annotated + Analyzed!"]
