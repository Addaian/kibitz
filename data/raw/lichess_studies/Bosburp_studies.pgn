[Event "Pure Brilliancy: Volume II: Hoi vs Gulko - Notes"]
[Date "2025.07.28"]
[White "Carsten Hoi"]
[Black "Boris Gulko"]
[Result "*"]
[Variant "Standard"]
[ECO "?"]
