1. e4 { [%clk 0:03:00] } 1... Nf6 { [%clk 0:03:00] } 2. e5 { [%clk 0:02:58] } 2... Nd5 { [%clk 0:02:59] } 3. d4 { [%clk 0:02:58] } 3... b5!? { This gambit is quite dubious, but it is very fun for blitz and bullet. This gambit also has a 52% win rate for black! } { [%csl Gb5] [%clk 0:02:57] } 4. Bxb5 { [%clk 0:02:53] } 4... c5 { we give away another pawn, but it allows the queen to come out. } { [%csl Ga5,Gb5][%cal Gd8a5,Ga5b5] [%clk 0:02:56] } 5. dxc5? { [%clk 0:02:48] } 5... Qa5+ { [%csl Gb5,Ge1][%cal Ga5b5,Ga5e1] [%clk 0:02:44] } 6. Qd2 { [%clk 0:02:39] } (6. Nc3 Nxc3 7. bxc3 Qxb5 { black has an extra piece and white has tripled pawns! } { [%csl Rc5,Rc3,Rc2] }) (6. Bd2 Qxb5 7. Nc3 Nxc3 8. Bxc3 Bb7 { [%csl Gg2][%cal Gb7g2] } 9. Nf3 Qxc5) (6. Nd2 Qxb5 7. c4 Qxc5 8. cxd5 Qxd5 { black has a +1.8 advantage }) 6... Qxb5 { [%clk 0:02:41] } 7. Qxd5 { [%clk 0:02:39] } 7... Bb7 { white cannot save the rook } { [%csl Gd5,Gg2,Gh1][%cal Gb7d5,Gd5g2,Gg2h1] [%clk 0:02:40] } 8. Qd4 { [%clk 0:02:27] } 8... Bxg2 { [%clk 0:02:35] } 9. a4 { [%clk 0:02:21] } 9... Qc6 { [%clk 0:02:19] } 10. b4 { [%clk 0:02:08] } 10... Bxh1 { [%clk 0:02:16] } 11. b5 { [%clk 0:02:07] } 11... Qe4+ { [%clk 0:02:14] } 12. Qxe4 { [%clk 0:02:05] } 12... Bxe4 { [%clk 0:02:14] } 13. c4 { [%clk 0:02:03] } 13... Bxb1 { [%clk 0:02:12] } 14. Rxb1 { [%clk 0:02:02] } 14... e6 { [%clk 0:02:11] } 15. Bg5 { [%clk 0:01:57] } 15... Bxc5 { 0-1 White resigns. } { [%clk 0:02:09] } 0-1


