[ChapterURL "https://lichess.org/study/0uRBskUV/hnDWxzap"]
[Annotator "https://lichess.org/@/Bosburp"]
[FEN "rnbqkb1r/ppp1pppp/5n2/8/2pP4/4PN2/PP3PPP/RNBQKB1R b KQkq - 0 4"]
[SetUp "1"]
[UTCDate "2024.01.17"]
[UTCTime "11:00:33"]

4... g6 { The Smylov Variation. Black wants to fianchetto the DSB and castle immediately. } 5. Bxc4 { We can grab that free pawn. } 5... Bg7 6. O-O { The king is now safely castled. } { [%csl Gg1] } 6... O-O { Doing the same. } (6... Bg4?? 7. Qb3! $18 { A fork! } { [%csl Gf7,Gb7][%cal Gb3f7,Gb3b7] } 7... O-O 8. Ne5! { Tripling up on f7! The b7 pawn is still left undefended. } { [%csl Gf7,Rb7][%cal Ge5f7,Yb3f7] } 8... e6 9. Qxb7 Nbd7 10. Nc6 { [%csl Gd8][%cal Gc6d8] } 10... Qe8 11. b3 $18 { White is completely winning. Black's position is completely crumbling. White has a +3.5 advantage. } { [%csl Ba3,Rc7,Gc6,Gb7,Gc4][%cal Bc1a3] }) 7. Nc3 $16 { White has a very comfortable position. The next step is to free up the DSB by pushing e4 sooner or later. } { [%csl Gc3,Gf3,Gc4,Bb3,Ba4,Be2,Gg1][%cal Bd1b3,Bd1e2,Bb3a4,Bf1e1,Be3e4] } *


[Event "Queen's Gambit | Full Repertoire: QGA: Janowski-Larsen Variation 3...Nf6 with 4...Bg4"]
[Date "2024.01.17"]
[Result "*"]
[Variant "Standard"]
[ECO "D25"]
