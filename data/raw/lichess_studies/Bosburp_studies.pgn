1. e4 { [%eval 0.36] [%clk 0:03:00] } 1... c5 { [%eval 0.32] [%clk 0:03:00] } 2. Nf3 { [%eval 0.0] [%clk 0:02:59] } 2... Nc6 { [%eval 0.0] [%clk 0:02:59] } 3. b4! { [%eval -0.49] [%clk 0:02:59] } 3... Nxb4 { [%eval -0.42] [%clk 0:02:58] } 4. c3 { [%eval -0.68] [%clk 0:02:57] } 4... Nc6 { [%eval -0.43] [%clk 0:02:57] } 5. d4 { [%eval -0.44] [%clk 0:02:57] } 5... cxd4 { [%eval -0.48] [%clk 0:02:56] } 6. cxd4 { [%eval -0.5] [%clk 0:02:57] } 6... d5 { [%eval -0.28] [%clk 0:02:56] } 7. exd5 { [%eval -0.12] [%clk 0:02:56] } 7... Qxd5 { [%eval -0.29] [%clk 0:02:55] } 8. Nc3 { [%eval -0.23] [%csl Gd5][%cal Gc3d5] [%clk 0:02:56] } 8... Qd8?? { [%eval 2.73] } { Blunder. Qa5 was best. } { [%clk 0:02:54] } (8... Qa5) 9. d5 { [%eval 2.5] [%csl Gc6][%cal Gd5c6] [%clk 0:02:55] } 9... Nb8 { [%eval 2.74] [%clk 0:02:50] } 10. Bb5+ { [%eval 2.43] [%clk 0:02:53] } 10... Bd7 { [%eval 2.74] [%clk 0:02:49] } 11. O-O { [%eval 2.76] [%clk 0:02:52] } 11... a6 { [%eval 3.15] [%clk 0:02:47] } 12. Qa4? { [%eval 1.53] } { Mistake. Bc4 was best. } { [%csl Ga8,Rb5][%cal Ga4a8,Ra6b5] [%clk 0:02:47] } (12. Bc4 Bg4 13. Re1 Nd7 14. Bb3 Ngf6 15. h3 Bxf3 16. Qxf3 Rc8 17. Bf4 h6 18. d6 e6) 12... Nf6? { [%eval 3.22] } { Mistake. Bxb5 was best. } { [%clk 0:02:45] } (12... Bxb5 13. Nxb5) 13. Re1 { [%eval 3.37] [%csl Ge7][%cal Ge1e7] [%clk 0:02:43] } 13... g6?! { [%eval 4.74] } { Inaccuracy. Bxb5 was best. } { [%clk 0:02:42] } (13... Bxb5 14. Nxb5 Nc6 15. dxc6 axb5 16. Qxb5 bxc6 17. Qxc6+ Nd7 18. Bb2 Rc8 19. Qa4 f6 20. Rad1) 14. Ba3 { [%eval 4.82] } { Black's plan is to put the bishop on g7 and castle, white has to prevent this.
at this point, black really doesn't has any moves. } { [%csl Ge7,Rg7][%cal Ga3e7,Ge1e7,Rf8g7] [%clk 0:02:41] } 14... Bxb5?! { [%eval 6.33] } { Inaccuracy. axb5 was best. } { [%clk 0:02:19] } (14... axb5 15. Qxa8 b4 16. Bxb4 Na6 17. Qxd8+ Kxd8 18. Ba5+ Kc8 19. Ne5 Be8 20. Rab1 Nc7 21. Red1) 15. Nxb5 { [%eval 6.35] [%clk 0:02:36] } 15... Nbd7?? { [%eval #1] } { Checkmate is now unavoidable. axb5 was best. } { [%clk 0:02:18] } (15... axb5 16. Qxa8 Nbd7 17. Qxb7 e6 18. Bxf8 Kxf8 19. dxe6 Kg7 20. exd7 Qxd7 21. Qxd7 Nxd7 22. Rec1) (15... Bg7 16. Bxe7) 16. Nd6# { 1-0 White wins by checkmate. } { [%csl Ge8,Rd6,Re7,Rf7,Bd8,Yd7,Yf8][%cal Gd6e8,Be1e8,Re7d6] [%clk 0:02:35] } 1-0


